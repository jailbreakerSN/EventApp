# ─── Firebase Web SDK ────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=teranga-events-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=teranga-events-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=teranga-events-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Cloud Messaging (Phase C.2 — Web Push) ─────────────────────────
# VAPID public key from Firebase Console → Project settings → Cloud Messaging
# → Web configuration → "Web push certificates". Required for getToken() to
# hand back an FCM registration token; without it, the push opt-in flow
# short-circuits to a graceful "unsupported" state.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Sentry (Wave 10 / W10-P1) ───────────────────────────────────────────────
# Optional. When unset, the SDK is loaded but stays inert (init no-ops). The
# server-only DSN is preferred so the secret never lands in the client bundle;
# NEXT_PUBLIC_SENTRY_DSN is the public DSN consumed by the browser SDK.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Promote CSP from Report-Only to enforced (W10-P2 / S1). Flip to "true" only
# after a 7-day clean window of /api/csp-report telemetry. Leave unset for the
# Report-Only ramp.
NEXT_PUBLIC_CSP_ENFORCE=

{
  "name": "@teranga/functions",
  "version": "0.1.0",
  "private": true,
  "description": "Teranga Firebase Cloud Functions — event triggers, background jobs",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@teranga/shared-types": "*",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.2",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.3"
  }
}

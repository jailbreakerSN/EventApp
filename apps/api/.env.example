# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Path to service account key JSON (local dev only — use Workload Identity in GCP)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.dev.json
FIREBASE_PROJECT_ID=teranga-events-dev
FIREBASE_STORAGE_BUCKET=teranga-events-dev.appspot.com

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@teranga.events

# ─── SMS (Africa's Talking) ──────────────────────────────────────────────────
AT_API_KEY=xxxx
AT_USERNAME=sandbox
AT_SENDER_ID=Teranga

# ─── QR Code Signing Secret ───────────────────────────────────────────────────
QR_SECRET=change-this-to-a-strong-secret-in-production

# ─── Webhook ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-this-too

{
  "firestore": {
    "rules": "infrastructure/firebase/firestore.rules",
    "indexes": "infrastructure/firebase/firestore.indexes.json"
  },
  "storage": [
    {
      "bucket": "teranga-events.appspot.com",
      "rules": "infrastructure/firebase/storage.rules"
    }
  ],
  "functions": [
    {
      "source": "apps/functions",
      "codebase": "teranga-functions",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"]
    }
  ],
  "hosting": {
    "source": "apps/web-backoffice",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "frameworksBackend": {
      "region": "europe-west1"
    }
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "pubsub": { "port": 8085 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}

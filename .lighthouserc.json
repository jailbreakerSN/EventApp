{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/types/lhci.schema.json",
  "ci": {
    "collect": {
      "startServerCommand": "npm run start --workspace=apps/web-backoffice -- --port 3001 & npm run start --workspace=apps/web-participant -- --port 3002",
      "startServerReadyPattern": "ready|started|listening",
      "url": [
        "http://localhost:3001/login",
        "http://localhost:3002/",
        "http://localhost:3002/events"
      ],
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

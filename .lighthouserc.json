{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/types/lhci.schema.json",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3001/login",
        "http://localhost:3002/",
        "http://localhost:3002/events"
      ],
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["uses-http2", "uses-text-compression"],
        "chromeFlags": "--no-sandbox --headless=new --disable-gpu --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "http://localhost:3002/$",
          "assertions": {
            "categories:performance": ["warn", { "minScore": 0.85 }],
            "categories:accessibility": ["warn", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        },
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:performance": ["warn", { "minScore": 0.85 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

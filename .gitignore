# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
lib/
# Web source directories share the `lib/` name but are NOT build output —
# re-include them so new files (e.g. apps/web-backoffice/src/lib/event-status.ts)
# aren't silently ignored.
!apps/**/src/lib/
!apps/**/src/lib/**
# Repo-root scripts may carry shared helpers under scripts/lib/ — those are
# source, not build output.
!scripts/lib/
!scripts/lib/**
venv/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code — ignore local state, but share project-level settings,
# skills, and subagents with the team. Per-user overrides stay local.
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/skills/
.claude/settings.local.json

# Code Review Graph (machine-specific binary DB)
.code-review-graph/

# Turbo
.turbo/

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Coverage
coverage/

# Storybook static build output
storybook-static/

# Flutter
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/build/
apps/mobile/*.g.dart
apps/mobile/**/*.g.dart
apps/mobile/**/*.freezed.dart

# Terraform
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/*.tfvars
!infrastructure/terraform/*.tfvars.example

# Service account keys — NEVER commit these
*.json.key
service-account*.json
*-service-account.json
*firebase_adminsdk*.json

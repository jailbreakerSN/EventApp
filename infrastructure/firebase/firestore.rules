rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function hasRole(role) {
      return isAuthenticated()
          && role in request.auth.token.roles;
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isOrganizer() {
      return hasRole('organizer');
    }

    function isStaff() {
      return hasRole('staff');
    }

    function belongsToOrg(orgId) {
      return isAuthenticated()
          && request.auth.token.organizationId == orgId;
    }

    function isOwnerOf(uid) {
      return isAuthenticated() && currentUid() == uid;
    }

    // Validates that only specific fields are being changed
    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // Validates that specific fields have NOT been changed (immutable on update)
    function immutableOnUpdate(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ─── Deny all by default ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwnerOf(userId) || isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(resource.data.organizationId));

      // Owner can update own profile fields; cannot change roles/uid/isActive.
      // `fcmTokens` is deliberately excluded from the owner-writable set:
      // client SDKs must NOT write push destinations directly — they flow
      // through POST /v1/me/fcm-tokens so the API can dedupe, cap at 10/user,
      // and emit `fcm.token_registered` to the audit trail. A client write
      // would bypass rate-limiting and the fingerprint audit (Phase C.1).
      allow update: if isOwnerOf(userId)
                    && onlyChanges(['displayName', 'photoURL', 'phone', 'bio',
                                    'preferredLanguage', 'updatedAt']);

      // Super admin can update everything (including roles)
      allow update: if isSuperAdmin();

      // Users are created by Cloud Functions (auth trigger), not directly
      allow create: if false;
      allow delete: if false;
    }

    // ─── Organizations ──────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (belongsToOrg(orgId) || isSuperAdmin());
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == currentUid();
      allow update: if (belongsToOrg(orgId) && isOrganizer()) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Events ─────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Published public events are readable by anyone (including unauthenticated for sharing links)
      allow read: if resource.data.status == 'published' && resource.data.isPublic == true;

      // Non-public or draft events: only org members, staff, or super admins
      allow read: if isAuthenticated()
                  && (belongsToOrg(resource.data.organizationId)
                      || isSuperAdmin());

      allow create: if (isOrganizer() && belongsToOrg(request.resource.data.organizationId))
                    || isSuperAdmin();

      allow update: if ((isOrganizer() && belongsToOrg(resource.data.organizationId))
                    || isSuperAdmin())
                    // Prevent cross-tenant migration: organizationId and createdBy are immutable
                    && request.resource.data.organizationId == resource.data.organizationId
                    // QR signing metadata is server-owned. A compromised
                    // organizer SDK token could otherwise overwrite `qrKid`
                    // with a value the attacker controls, derive the
                    // matching HKDF key, and mint forged valid v4 QRs.
                    // Rotation must flow exclusively through
                    // `POST /v1/events/:eventId/qr-key/rotate` (Admin SDK).
                    && immutableOnUpdate(['createdBy', 'organizationId', 'qrKid', 'qrKidHistory']);

      // Soft-delete only — set status to 'archived'
      allow delete: if false;
    }

    // ─── Sessions (Agenda) ─────────────────────────────────────────────────
    match /sessions/{sessionId} {
      // Sessions for published events are readable by any authenticated user (participants need agenda)
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'published';

      // Sessions for non-published events: only org members or super admins
      allow read: if isAuthenticated()
                  && (belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ) || isSuperAdmin());

      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                       get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizationId
                    ));

      allow update: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                       get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    ));

      allow delete: if isSuperAdmin();
    }

    // ─── Registrations ──────────────────────────────────────────────────────
    match /registrations/{regId} {
      // Owner can read their own registration
      allow read: if isOwnerOf(resource.data.userId);

      // Organizers/staff can only read registrations for events in their org
      allow read: if (isOrganizer() || isStaff())
                  && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  );

      // Super admin can read all
      allow read: if isSuperAdmin();

      // Participants register themselves — validated in API but guard here too
      allow create: if isAuthenticated()
                    && request.resource.data.userId == currentUid()
                    && request.resource.data.status in ['confirmed', 'pending', 'waitlisted'];

      // Participant can only cancel their own registration
      allow update: if isOwnerOf(resource.data.userId)
                    && onlyChanges(['status', 'updatedAt'])
                    && request.resource.data.status == 'cancelled'
                    && immutableOnUpdate(['userId', 'eventId', 'ticketTypeId', 'createdAt']);

      // Staff and organizer can update status and check-in fields — org-scoped
      allow update: if (isOrganizer() || isStaff())
                    && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    )
                    && onlyChanges(['status', 'checkedInAt', 'checkedInBy',
                                    'checkedInDeviceId', 'accessZoneId', 'updatedAt'])
                    && immutableOnUpdate(['userId', 'eventId', 'ticketTypeId', 'createdAt']);

      // Super admin can update any field
      allow update: if isSuperAdmin();

      allow delete: if false;
    }

    // ─── Badges ─────────────────────────────────────────────────────────────
    match /badges/{badgeId} {
      // Owner can read their own badge; organizers only for their org's events
      allow read: if isOwnerOf(resource.data.userId)
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ))
                  || isSuperAdmin();

      // Created via API, which writes using Admin SDK
      allow create: if false;
      allow update: if false; // only Admin SDK (Cloud Functions update pdfURL)
      allow delete: if false;
    }

    match /badgeTemplates/{templateId} {
      allow read: if (isOrganizer() && belongsToOrg(resource.data.organizationId))
                  || isSuperAdmin();
      allow create: if (isOrganizer() && belongsToOrg(request.resource.data.organizationId))
                    || isSuperAdmin();
      allow update: if ((isOrganizer() && belongsToOrg(resource.data.organizationId))
                    || isSuperAdmin())
                    && immutableOnUpdate(['organizationId', 'createdBy']);
      allow delete: if isSuperAdmin();
    }

    // ─── Conversations & Messages ────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isAuthenticated()
                  && currentUid() in resource.data.participantIds;

      allow create: if isAuthenticated()
                    && currentUid() in request.resource.data.participantIds
                    && request.resource.data.participantIds.size() == 2;

      allow update: if isAuthenticated()
                    && currentUid() in resource.data.participantIds;

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthenticated()
                    && currentUid() in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        allow create: if isAuthenticated()
                      && request.resource.data.senderId == currentUid();

        // Soft-delete own messages only (set deletedAt)
        allow update: if isOwnerOf(resource.data.senderId)
                      && onlyChanges(['deletedAt', 'updatedAt']);

        allow delete: if false;
      }
    }

    // ─── Feed Posts ─────────────────────────────────────────────────────────
    match /feedPosts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
                    && request.resource.data.authorId == currentUid();

      allow update: if isOwnerOf(resource.data.authorId)
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    ))
                    || isSuperAdmin();

      // Soft-delete — set deletedAt
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
                      && request.resource.data.authorId == currentUid();
        // Author can only soft-delete (set deletedAt) or edit content
        allow update: if isOwnerOf(resource.data.authorId)
                      && onlyChanges(['content', 'deletedAt', 'updatedAt']);
        allow delete: if false;
      }
    }

    // ─── Notifications ───────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isOwnerOf(resource.data.userId);

      // Users can only mark as read
      allow update: if isOwnerOf(resource.data.userId)
                    && onlyChanges(['isRead', 'readAt']);

      // Created only by Cloud Functions (Admin SDK)
      allow create: if false;
      allow delete: if false;
    }

    // ─── Payments ────────────────────────────────────────────────────────────
    // Written exclusively by API / Cloud Functions via Admin SDK.
    // Participants can read their own; organizers can read for their org's events.
    match /payments/{paymentId} {
      allow read: if isOwnerOf(resource.data.userId)
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ))
                  || isSuperAdmin();
      allow create, update, delete: if false;  // Only Admin SDK (API + Cloud Functions)
    }

    // ─── Audit Logs ─────────────────────────────────────────────────────────
    // Written exclusively by the API via Admin SDK (fire-and-forget).
    // Only super admins can read audit logs from the client.
    // No client writes, updates, or deletes.
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Balance Transactions (ledger) ──────────────────────────────────────
    // Append-only ledger; every money movement produces one entry.
    // Written exclusively by the API inside domain-service transactions
    // (payment.succeeded, refund, payout.create). Never from the client.
    // Readable by organizers of the owning org (for the /finance page) and
    // by super admins (platform oversight).
    match /balanceTransactions/{txId} {
      allow read: if isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(resource.data.organizationId));
      allow create, update, delete: if false;  // Only Admin SDK (API + schedulers)
    }

    // ─── Per-scan forensic log (checkins) ───────────────────────────────────
    // One row per scan attempt — success, duplicate, or rejected. Written
    // exclusively by the API via Admin SDK; no client writes at any role
    // level. Read by organizers/staff of the event's org for the security
    // dashboard (Sprint C item 4.3), and by super admins for platform
    // oversight. `organizationId` is denormalised on the doc so the rule
    // doesn't need a `get()` hop per evaluation.
    match /checkins/{checkinId} {
      allow read: if isSuperAdmin()
                  || ((isOrganizer() || isStaff())
                      && belongsToOrg(resource.data.organizationId));
      allow create, update, delete: if false;  // Admin SDK only
    }

    // ─── Scan-policy uniqueness locks (checkinLocks) ────────────────────────
    // Internal implementation detail of the multi-entry / multi-zone scan
    // pipeline — doc ids encode `(registrationId, scope)` and each
    // existence-check gates the next successful scan. No client ever reads
    // or writes these; Admin SDK only.
    match /checkinLocks/{lockId} {
      allow read, write: if false;
    }

    // ─── Offline Sync Data ──────────────────────────────────────────────────
    // Cached registration data for staff QR scanning when offline.
    // Written by Admin SDK, readable only by staff/organizers of the same org.
    match /offlineSync/{docId} {
      allow read: if isSuperAdmin()
                  || ((isStaff() || isOrganizer())
                      && belongsToOrg(resource.data.organizationId));
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Check-in Feed ─────────────────────────────────────────────────────
    // Real-time check-in entries written by Cloud Function trigger.
    // Readable by staff/organizers of the same org for live dashboards.
    match /checkinFeed/{feedId} {
      allow read: if isSuperAdmin()
                  || ((isStaff() || isOrganizer())
                      && belongsToOrg(resource.data.organizationId));
      allow create: if false;  // Only Admin SDK (Cloud Function)
      allow update: if false;
      allow delete: if false;
    }

    // ─── Speakers ───────────────────────────────────────────────────────────
    // Speaker profiles linked to events.
    // Authenticated users can read speakers of published events.
    // Org members and super_admin can read all speakers for their events.
    match /speakers/{speakerId} {
      // Anyone authenticated can read speakers of published events
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'published';

      // Org members and super_admin can read all (including draft events)
      allow read: if isAuthenticated()
                  && (belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ) || isSuperAdmin());

      // Only organizers of the event's org or super_admin can create
      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizationId
                    ));

      // Organizers of the event's org or super_admin can update all fields
      allow update: if (isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    )))
                    && immutableOnUpdate(['eventId', 'organizationId', 'createdBy']);

      // The speaker themselves can update profile fields only
      allow update: if isOwnerOf(resource.data.userId)
                    && onlyChanges(['bio', 'photoURL', 'slidesUrl', 'updatedAt'])
                    && immutableOnUpdate(['eventId', 'organizationId', 'createdBy']);

      // Soft-delete only
      allow delete: if false;
    }

    // ─── Sponsors ───────────────────────────────────────────────────────────
    // Sponsor profiles linked to events.
    match /sponsors/{sponsorId} {
      // Authenticated users can read sponsors of published events
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'published';

      // Org members and super_admin can read all
      allow read: if isAuthenticated()
                  && (belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ) || isSuperAdmin());

      // Only organizers of the event's org or super_admin can create
      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizationId
                    ));

      // Organizers of the event's org or super_admin can update; eventId and organizationId are immutable
      allow update: if (isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    )))
                    && immutableOnUpdate(['eventId', 'organizationId']);

      // Soft-delete only
      allow delete: if false;
    }

    // ─── Sponsor Leads ──────────────────────────────────────────────────────
    // Leads captured by sponsors at events.
    // Written by authenticated sponsor users, read by sponsor owner / org organizers / super_admin.
    match /sponsorLeads/{leadId} {
      // The sponsor user who captured the lead can read it
      allow read: if isOwnerOf(resource.data.scannedBy);

      // Org organizers can read leads for their org's events
      allow read: if isOrganizer()
                  && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  );

      // Super admin can read all
      allow read: if isSuperAdmin();

      // Authenticated sponsor captures leads at events
      allow create: if isAuthenticated()
                    && request.resource.data.scannedBy == currentUid();

      // Updates and deletes via Admin SDK only
      allow update: if false;
      allow delete: if false;
    }

    // ─── Venues ─────────────────────────────────────────────────────────────
    // Venues are semi-public — any authenticated user can read (needed for event listings).
    // Managed by organizers of the host organization or super_admin.
    match /venues/{venueId} {
      allow read: if isAuthenticated();

      allow create: if isOrganizer() || isSuperAdmin();

      // Only organizers belonging to the venue's host org or super_admin can update
      allow update: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(resource.data.hostOrganizationId));

      // Soft-delete only
      allow delete: if false;
    }

    // ─── Broadcasts ─────────────────────────────────────────────────────────
    // Event broadcasts (emails, push notifications, SMS).
    // Created exclusively by Admin SDK (API). Org organizers can read.
    match /broadcasts/{broadcastId} {
      // Organizers of the event's org or super_admin can read
      allow read: if isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ));

      // Admin SDK only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Promo Codes ────────────────────────────────────────────────────────
    // Discount / promo codes for event tickets.
    // Managed exclusively by Admin SDK (API). Org organizers can read.
    match /promoCodes/{codeId} {
      // Organizers of the event's org or super_admin can read
      allow read: if isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ));

      // Admin SDK / API only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Invites ────────────────────────────────────────────────────────────
    // Invitations to events or organizations.
    // Invitees matched by email; org members and super_admin can read.
    match /invites/{inviteId} {
      // The invitee (matched by email) can read their own invite
      allow read: if isAuthenticated()
                  && resource.data.email == request.auth.token.email;

      // Org members can read invites for their org
      allow read: if isAuthenticated()
                  && belongsToOrg(resource.data.organizationId);

      // Super admin can read all
      allow read: if isSuperAdmin();

      // Organizers of the invite's org or super_admin can create invites
      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(request.resource.data.organizationId));

      // Invitee can accept or decline (status change only)
      allow update: if isAuthenticated()
                    && resource.data.email == request.auth.token.email
                    && onlyChanges(['status', 'respondedAt', 'updatedAt'])
                    && request.resource.data.status in ['accepted', 'declined'];

      // Org organizers can revoke invites
      allow update: if (isOrganizer() && belongsToOrg(resource.data.organizationId))
                    && onlyChanges(['status', 'updatedAt'])
                    && request.resource.data.status == 'revoked';

      // Super admin can update any field
      allow update: if isSuperAdmin();

      // No hard deletes
      allow delete: if false;
    }

    // ─── Newsletter Subscribers ─────────────────────────────────────────────
    // Email subscribers managed exclusively by the API + Cloud Functions
    // (double-opt-in subscribe/confirm, retention pruning, Resend webhook
    // deactivations). Only super_admin can read from the client.
    //
    // Immutability caveat: consent-critical fields (`status`,
    // `subscribedAt`, `confirmedAt`) are enforced by the API service
    // layer, NOT by rules. Rules deny every client write and Admin SDK
    // bypasses rules entirely, so a buggy migration script could in
    // theory overwrite `confirmedAt` or flip `status: "confirmed"` back
    // to `"pending"`. Accepted tradeoff: all writers are in-repo code
    // (api + functions), reviewed against this invariant, and covered
    // by domain-event audit trail. A future hardening pass could
    // introduce client-side `immutableOnUpdate` guards if we ever
    // expose writes from outside Admin SDK.
    match /newsletterSubscribers/{subId} {
      allow read: if isSuperAdmin();

      // API only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Email Suppressions ─────────────────────────────────────────────────
    // Hard-bounce + complaint list written by the resendWebhook Cloud
    // Function (doc id = lowercased email). Readable by super_admin for
    // the "why didn't this recipient get my email?" diagnostic view;
    // writes are Admin SDK only — never from the client.
    match /emailSuppressions/{email} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Notification Settings (Phase 1) ────────────────────────────────────
    // Per-notification-key admin overrides. Doc id = notification key
    // (e.g. "registration.created"). Body = NotificationSetting from
    // @teranga/shared-types. Readable by super_admin for the admin
    // notifications UI (Phase 4); all writes go through the admin API
    // which enforces `platform:manage` and emits notification.setting_updated
    // for audit. Client-side writes are blocked even for super-admins to
    // preserve the audit trail.
    match /notificationSettings/{key} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    // ─── Notification Dispatch Log (Phase 5 — v2) ───────────────────────────
    // Append-only send log written by the dispatcher once observability
    // ships. Server-only; super_admin reads power the "recent sends"
    // diagnostic drawer. Collection exists now so the rules surface is
    // locked down ahead of the v2 writer.
    match /notificationDispatchLog/{id} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    // ─── Plan Catalog ──────────────────────────────────────────────────────
    // Superadmin-managed catalog of subscription plans. Any authenticated
    // user can read published (public, non-archived) plans so the billing
    // page works without elevated permissions. Superadmins can read every
    // plan, including archived/private ones.
    // Writes go through the API (admin routes) — client-side mutations are
    // blocked even for superadmins to preserve audit trail and validation.
    match /plans/{planId} {
      allow read: if isAuthenticated()
                  && resource.data.isPublic == true
                  && resource.data.isArchived == false;
      allow read: if isSuperAdmin();

      allow create, update, delete: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function hasRole(role) {
      return isAuthenticated()
          && role in request.auth.token.roles;
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isOrganizer() {
      return hasRole('organizer');
    }

    function isStaff() {
      return hasRole('staff');
    }

    function belongsToOrg(orgId) {
      return isAuthenticated()
          && request.auth.token.organizationId == orgId;
    }

    function isOwnerOf(uid) {
      return isAuthenticated() && currentUid() == uid;
    }

    // Validates that only specific fields are being changed
    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // Validates that specific fields have NOT been changed (immutable on update)
    function immutableOnUpdate(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ─── Deny all by default ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwnerOf(userId) || isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(resource.data.organizationId));

      // Owner can update own profile fields; cannot change roles/uid/isActive.
      // `fcmTokens` is deliberately excluded from the owner-writable set:
      // client SDKs must NOT write push destinations directly — they flow
      // through POST /v1/me/fcm-tokens so the API can dedupe, cap at 10/user,
      // and emit `fcm.token_registered` to the audit trail. A client write
      // would bypass rate-limiting and the fingerprint audit (Phase C.1).
      allow update: if isOwnerOf(userId)
                    && onlyChanges(['displayName', 'photoURL', 'phone', 'bio',
                                    'preferredLanguage', 'updatedAt']);

      // Super admin can update everything (including roles)
      allow update: if isSuperAdmin();

      // Users are created by Cloud Functions (auth trigger), not directly
      allow create: if false;
      allow delete: if false;
    }

    // ─── Organizations ──────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (belongsToOrg(orgId) || isSuperAdmin());
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == currentUid();
      allow update: if (belongsToOrg(orgId) && isOrganizer()) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Events ─────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Published public events are readable by anyone (including unauthenticated for sharing links)
      allow read: if resource.data.status == 'published' && resource.data.isPublic == true;

      // Non-public or draft events: only org members, staff, or super admins
      allow read: if isAuthenticated()
                  && (belongsToOrg(resource.data.organizationId)
                      || isSuperAdmin());

      allow create: if (isOrganizer() && belongsToOrg(request.resource.data.organizationId))
                    || isSuperAdmin();

      allow update: if ((isOrganizer() && belongsToOrg(resource.data.organizationId))
                    || isSuperAdmin())
                    // Prevent cross-tenant migration: organizationId and createdBy are immutable
                    && request.resource.data.organizationId == resource.data.organizationId
                    // QR signing metadata is server-owned. A compromised
                    // organizer SDK token could otherwise overwrite `qrKid`
                    // with a value the attacker controls, derive the
                    // matching HKDF key, and mint forged valid v4 QRs.
                    // Rotation must flow exclusively through
                    // `POST /v1/events/:eventId/qr-key/rotate` (Admin SDK).
                    // Phase 7+ item #B1 — series-anchor fields (`isRecurringParent`,
                    // `parentEventId`, `occurrenceIndex`) are server-stamped at create
                    // time and MUST stay immutable. Otherwise a compromised client
                    // could flip a parent's `isRecurringParent: false` to leak the
                    // anchor onto participant discovery, or set `parentEventId` on
                    // an unrelated event to attach it to a foreign series.
                    && immutableOnUpdate([
                      'createdBy',
                      'organizationId',
                      'qrKid',
                      'qrKidHistory',
                      'isRecurringParent',
                      'parentEventId',
                      'occurrenceIndex',
                    ]);

      // Soft-delete only — set status to 'archived'
      allow delete: if false;
    }

    // ─── Sessions (Agenda) ─────────────────────────────────────────────────
    match /sessions/{sessionId} {
      // Sessions for published events are readable by any authenticated user (participants need agenda)
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'published';

      // Sessions for non-published events: only org members or super admins
      allow read: if isAuthenticated()
                  && (belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ) || isSuperAdmin());

      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                       get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizationId
                    ));

      allow update: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                       get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    ));

      allow delete: if isSuperAdmin();
    }

    // ─── Registrations ──────────────────────────────────────────────────────
    match /registrations/{regId} {
      // Owner can read their own registration
      allow read: if isOwnerOf(resource.data.userId);

      // Organizers/staff can only read registrations for events in their org
      allow read: if (isOrganizer() || isStaff())
                  && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  );

      // Super admin can read all
      allow read: if isSuperAdmin();

      // B2 follow-up — registration creation is API-only.
      // Pre-fix the rule allowed any authenticated participant to write
      // a registration directly with `status: ['confirmed', 'pending',
      // 'waitlisted']`, bypassing every server-side guard:
      //   - Plan participant-per-event cap (free=50, starter=200, pro=2000)
      //   - Event-level + ticket-type capacity check
      //   - Email verification on paid tickets
      //   - HMAC QR code signing (no qrCodeValue → badge unprintable)
      //   - registeredCount counter increment (capacity drift)
      //   - waitlist plan-feature gate (free orgs would self-grant waitlist)
      // The API uses the Admin SDK and is exempt from these rules; an
      // org-wide audit (B2 senior review) confirmed no client code does
      // direct registration writes (web-participant, web-backoffice, and
      // the Flutter mobile app all route through the API). Locking the
      // create path closes the gap without breaking any client flow.
      allow create: if false;

      // Participant can only cancel their own registration
      allow update: if isOwnerOf(resource.data.userId)
                    && onlyChanges(['status', 'updatedAt'])
                    && request.resource.data.status == 'cancelled'
                    && immutableOnUpdate(['userId', 'eventId', 'ticketTypeId', 'createdAt']);

      // Staff and organizer can update status and check-in fields — org-scoped
      allow update: if (isOrganizer() || isStaff())
                    && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    )
                    && onlyChanges(['status', 'checkedInAt', 'checkedInBy',
                                    'checkedInDeviceId', 'accessZoneId', 'updatedAt'])
                    && immutableOnUpdate(['userId', 'eventId', 'ticketTypeId', 'createdAt']);

      // Super admin can update any field
      allow update: if isSuperAdmin();

      allow delete: if false;
    }

    // ─── Badges ─────────────────────────────────────────────────────────────
    match /badges/{badgeId} {
      // Owner can read their own badge; organizers only for their org's events
      allow read: if isOwnerOf(resource.data.userId)
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ))
                  || isSuperAdmin();

      // Created via API, which writes using Admin SDK
      allow create: if false;
      allow update: if false; // only Admin SDK (Cloud Functions update pdfURL)
      allow delete: if false;
    }

    match /badgeTemplates/{templateId} {
      allow read: if (isOrganizer() && belongsToOrg(resource.data.organizationId))
                  || isSuperAdmin();
      allow create: if (isOrganizer() && belongsToOrg(request.resource.data.organizationId))
                    || isSuperAdmin();
      allow update: if ((isOrganizer() && belongsToOrg(resource.data.organizationId))
                    || isSuperAdmin())
                    && immutableOnUpdate(['organizationId', 'createdBy']);
      allow delete: if isSuperAdmin();
    }

    // ─── Conversations & Messages ────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isAuthenticated()
                  && currentUid() in resource.data.participantIds;

      allow create: if isAuthenticated()
                    && currentUid() in request.resource.data.participantIds
                    && request.resource.data.participantIds.size() == 2;

      allow update: if isAuthenticated()
                    && currentUid() in resource.data.participantIds;

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthenticated()
                    && currentUid() in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        allow create: if isAuthenticated()
                      && request.resource.data.senderId == currentUid();

        // Soft-delete own messages only (set deletedAt)
        allow update: if isOwnerOf(resource.data.senderId)
                      && onlyChanges(['deletedAt', 'updatedAt']);

        allow delete: if false;
      }
    }

    // ─── Feed Posts ─────────────────────────────────────────────────────────
    match /feedPosts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
                    && request.resource.data.authorId == currentUid();

      allow update: if isOwnerOf(resource.data.authorId)
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    ))
                    || isSuperAdmin();

      // Soft-delete — set deletedAt
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
                      && request.resource.data.authorId == currentUid();
        // Author can only soft-delete (set deletedAt) or edit content
        allow update: if isOwnerOf(resource.data.authorId)
                      && onlyChanges(['content', 'deletedAt', 'updatedAt']);
        allow delete: if false;
      }
    }

    // ─── Notifications ───────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isOwnerOf(resource.data.userId);

      // Users can only mark as read
      allow update: if isOwnerOf(resource.data.userId)
                    && onlyChanges(['isRead', 'readAt']);

      // Created only by Cloud Functions (Admin SDK)
      allow create: if false;
      allow delete: if false;
    }

    // ─── Payments ────────────────────────────────────────────────────────────
    // Written exclusively by API / Cloud Functions via Admin SDK.
    // Participants can read their own; organizers can read for their org's events.
    match /payments/{paymentId} {
      allow read: if isOwnerOf(resource.data.userId)
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ))
                  || isSuperAdmin();
      allow create, update, delete: if false;  // Only Admin SDK (API + Cloud Functions)
    }

    // ─── Audit Logs ─────────────────────────────────────────────────────────
    // Written exclusively by the API via Admin SDK (fire-and-forget).
    // Only super admins can read audit logs from the client.
    // No client writes, updates, or deletes.
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Balance Transactions (ledger) ──────────────────────────────────────
    // Append-only ledger; every money movement produces one entry.
    // Written exclusively by the API inside domain-service transactions
    // (payment.succeeded, refund, payout.create). Never from the client.
    // Readable by organizers of the owning org (for the /finance page) and
    // by super admins (platform oversight).
    match /balanceTransactions/{txId} {
      allow read: if isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(resource.data.organizationId));
      allow create, update, delete: if false;  // Only Admin SDK (API + schedulers)
    }

    // ─── Per-scan forensic log (checkins) ───────────────────────────────────
    // One row per scan attempt — success, duplicate, or rejected. Written
    // exclusively by the API via Admin SDK; no client writes at any role
    // level. Read by organizers/staff of the event's org for the security
    // dashboard (Sprint C item 4.3), and by super admins for platform
    // oversight. `organizationId` is denormalised on the doc so the rule
    // doesn't need a `get()` hop per evaluation.
    match /checkins/{checkinId} {
      allow read: if isSuperAdmin()
                  || ((isOrganizer() || isStaff())
                      && belongsToOrg(resource.data.organizationId));
      allow create, update, delete: if false;  // Admin SDK only
    }

    // ─── Scan-policy uniqueness locks (checkinLocks) ────────────────────────
    // Internal implementation detail of the multi-entry / multi-zone scan
    // pipeline — doc ids encode `(registrationId, scope)` and each
    // existence-check gates the next successful scan. No client ever reads
    // or writes these; Admin SDK only.
    match /checkinLocks/{lockId} {
      allow read, write: if false;
    }

    // ─── Offline Sync Data ──────────────────────────────────────────────────
    // Cached registration data for staff QR scanning when offline.
    // Written by Admin SDK, readable only by staff/organizers of the same org.
    match /offlineSync/{docId} {
      allow read: if isSuperAdmin()
                  || ((isStaff() || isOrganizer())
                      && belongsToOrg(resource.data.organizationId));
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Check-in Feed ─────────────────────────────────────────────────────
    // Real-time check-in entries written by Cloud Function trigger.
    // Readable by staff/organizers of the same org for live dashboards.
    match /checkinFeed/{feedId} {
      allow read: if isSuperAdmin()
                  || ((isStaff() || isOrganizer())
                      && belongsToOrg(resource.data.organizationId));
      allow create: if false;  // Only Admin SDK (Cloud Function)
      allow update: if false;
      allow delete: if false;
    }

    // ─── Speakers ───────────────────────────────────────────────────────────
    // Speaker profiles linked to events.
    // Authenticated users can read speakers of published events.
    // Org members and super_admin can read all speakers for their events.
    match /speakers/{speakerId} {
      // Anyone authenticated can read speakers of published events
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'published';

      // Org members and super_admin can read all (including draft events)
      allow read: if isAuthenticated()
                  && (belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ) || isSuperAdmin());

      // Only organizers of the event's org or super_admin can create
      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizationId
                    ));

      // Organizers of the event's org or super_admin can update all fields
      allow update: if (isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    )))
                    && immutableOnUpdate(['eventId', 'organizationId', 'createdBy']);

      // The speaker themselves can update profile fields only
      allow update: if isOwnerOf(resource.data.userId)
                    && onlyChanges(['bio', 'photoURL', 'slidesUrl', 'updatedAt'])
                    && immutableOnUpdate(['eventId', 'organizationId', 'createdBy']);

      // Soft-delete only
      allow delete: if false;
    }

    // ─── Sponsors ───────────────────────────────────────────────────────────
    // Sponsor profiles linked to events.
    match /sponsors/{sponsorId} {
      // Authenticated users can read sponsors of published events
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'published';

      // Org members and super_admin can read all
      allow read: if isAuthenticated()
                  && (belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ) || isSuperAdmin());

      // Only organizers of the event's org or super_admin can create
      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizationId
                    ));

      // Organizers of the event's org or super_admin can update; eventId and organizationId are immutable
      allow update: if (isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(
                        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                    )))
                    && immutableOnUpdate(['eventId', 'organizationId']);

      // Soft-delete only
      allow delete: if false;
    }

    // ─── Sponsor Leads ──────────────────────────────────────────────────────
    // Leads captured by sponsors at events.
    // Written by authenticated sponsor users, read by sponsor owner / org organizers / super_admin.
    match /sponsorLeads/{leadId} {
      // The sponsor user who captured the lead can read it
      allow read: if isOwnerOf(resource.data.scannedBy);

      // Org organizers can read leads for their org's events
      allow read: if isOrganizer()
                  && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  );

      // Super admin can read all
      allow read: if isSuperAdmin();

      // Authenticated sponsor captures leads at events
      allow create: if isAuthenticated()
                    && request.resource.data.scannedBy == currentUid();

      // Updates and deletes via Admin SDK only
      allow update: if false;
      allow delete: if false;
    }

    // ─── Venues ─────────────────────────────────────────────────────────────
    // Venues are semi-public — any authenticated user can read (needed for event listings).
    // Managed by organizers of the host organization or super_admin.
    match /venues/{venueId} {
      allow read: if isAuthenticated();

      allow create: if isOrganizer() || isSuperAdmin();

      // Only organizers belonging to the venue's host org or super_admin can update
      allow update: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(resource.data.hostOrganizationId));

      // Soft-delete only
      allow delete: if false;
    }

    // ─── Broadcasts ─────────────────────────────────────────────────────────
    // Event broadcasts (emails, push notifications, SMS).
    // Created exclusively by Admin SDK (API). Org organizers can read.
    match /broadcasts/{broadcastId} {
      // Organizers of the event's org or super_admin can read
      allow read: if isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ));

      // Admin SDK only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Promo Codes ────────────────────────────────────────────────────────
    // Discount / promo codes for event tickets.
    // Managed exclusively by Admin SDK (API). Org organizers can read.
    match /promoCodes/{codeId} {
      // Organizers of the event's org or super_admin can read
      allow read: if isSuperAdmin()
                  || (isOrganizer() && belongsToOrg(
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId
                  ));

      // Admin SDK / API only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Plan Coupons (Phase 7+ item #7) ────────────────────────────────────
    // Subscription / plan-level promo codes. Super-admin only at the rules
    // layer — create/update/archive flow through the API
    // (planCouponService), never a direct client write. Reads are denied
    // to clients too: the billing UI consumes the admin list endpoint
    // (platform:manage) for management and the
    // `/v1/plans/:planId/validate-coupon` endpoint for the dry-run preview.
    // There is NO read path where an org could enumerate coupons to find
    // a discount they aren't supposed to know about.
    match /planCoupons/{couponId} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    // ─── Coupon Redemptions (Phase 7+ item #7) ──────────────────────────────
    // Append-only audit trail of coupon redemptions. One doc per successful
    // redeem. Written transactionally alongside the subscription upgrade
    // by the API — never by a client. Super-admin reads for forensics;
    // orgs can read their own redemptions (denorm lives on the
    // subscription.appliedCoupon field too, so most UI needs don't hit
    // this collection directly).
    match /couponRedemptions/{redemptionId} {
      allow read: if isSuperAdmin()
                  || (isAuthenticated() && belongsToOrg(resource.data.organizationId));
      allow create, update, delete: if false;
    }

    // ─── Invites ────────────────────────────────────────────────────────────
    // Invitations to events or organizations.
    // Invitees matched by email; org members and super_admin can read.
    match /invites/{inviteId} {
      // The invitee (matched by email) can read their own invite
      allow read: if isAuthenticated()
                  && resource.data.email == request.auth.token.email;

      // Org members can read invites for their org
      allow read: if isAuthenticated()
                  && belongsToOrg(resource.data.organizationId);

      // Super admin can read all
      allow read: if isSuperAdmin();

      // Organizers of the invite's org or super_admin can create invites
      allow create: if isSuperAdmin()
                    || (isOrganizer() && belongsToOrg(request.resource.data.organizationId));

      // Invitee can accept or decline (status change only)
      allow update: if isAuthenticated()
                    && resource.data.email == request.auth.token.email
                    && onlyChanges(['status', 'respondedAt', 'updatedAt'])
                    && request.resource.data.status in ['accepted', 'declined'];

      // Org organizers can revoke invites
      allow update: if (isOrganizer() && belongsToOrg(resource.data.organizationId))
                    && onlyChanges(['status', 'updatedAt'])
                    && request.resource.data.status == 'revoked';

      // Super admin can update any field
      allow update: if isSuperAdmin();

      // No hard deletes
      allow delete: if false;
    }

    // ─── Newsletter Subscribers ─────────────────────────────────────────────
    // Email subscribers managed exclusively by the API + Cloud Functions
    // (double-opt-in subscribe/confirm, retention pruning, Resend webhook
    // deactivations). Only super_admin can read from the client.
    //
    // Immutability caveat: consent-critical fields (`status`,
    // `subscribedAt`, `confirmedAt`) are enforced by the API service
    // layer, NOT by rules. Rules deny every client write and Admin SDK
    // bypasses rules entirely, so a buggy migration script could in
    // theory overwrite `confirmedAt` or flip `status: "confirmed"` back
    // to `"pending"`. Accepted tradeoff: all writers are in-repo code
    // (api + functions), reviewed against this invariant, and covered
    // by domain-event audit trail. A future hardening pass could
    // introduce client-side `immutableOnUpdate` guards if we ever
    // expose writes from outside Admin SDK.
    match /newsletterSubscribers/{subId} {
      allow read: if isSuperAdmin();

      // API only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Email Suppressions ─────────────────────────────────────────────────
    // Hard-bounce + complaint list written by the resendWebhook Cloud
    // Function (doc id = lowercased email). Readable by super_admin for
    // the "why didn't this recipient get my email?" diagnostic view;
    // writes are Admin SDK only — never from the client.
    match /emailSuppressions/{email} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Notification Settings (Phase 1) ────────────────────────────────────
    // Per-notification-key admin overrides. Doc id = notification key
    // (e.g. "registration.created"). Body = NotificationSetting from
    // @teranga/shared-types. Readable by super_admin for the admin
    // notifications UI (Phase 4); all writes go through the admin API
    // which enforces `platform:manage` and emits notification.setting_updated
    // for audit. Client-side writes are blocked even for super-admins to
    // preserve the audit trail.
    match /notificationSettings/{key} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    // ─── Notification Dispatch Log (Phase 5 — v2) ───────────────────────────
    // Append-only send log written by the dispatcher. Used by:
    //   • /v1/notifications/history (per-user, tenant-scoped)
    //   • /v1/admin/notifications/delivery (super-admin aggregate,
    //     Phase D.3 observability dashboard)
    //   • /v1/admin/notifications/stats (legacy per-key counters)
    //   • The Resend webhook + the SW push-displayed / push-clicked
    //     routes for delivery back-annotation (Phase 2.5 + D.2).
    // Every caller above goes through the audited API — never through
    // the client SDK — so the rule is `allow read: if false;`. The
    // Admin SDK bypasses rules, so server-side service code continues
    // to work. Super-admins doing ad-hoc debugging use the Firebase
    // Console (auth at the Google-identity layer, separately audited).
    //
    // Phase D review (M-2): this was previously `allow read: if
    // isSuperAdmin()`, which opened a client-SDK enumeration surface
    // that bypassed the API's audit log. No web-app caller ever used
    // that path (grep for `collection("notificationDispatchLog")` in
    // apps/web-* returns zero hits). Tightening the rule closes the
    // enumeration surface without breaking any caller; if a future
    // super-admin tool needs client-SDK read access, add a
    // dedicated, audit-logged API endpoint instead of re-opening the
    // rule.
    //
    // Cross-reference: apps/api/src/repositories/notification-
    // dispatch-log.repository.ts header carries a matching comment
    // explaining why the composite indexes on this collection do
    // NOT open an exploitation surface.
    match /notificationDispatchLog/{id} {
      allow read, create, update, delete: if false;
    }

    // ─── Rate-limit Buckets (Phase D.4) ─────────────────────────────────────
    // Distributed per-(scope, identifier, window) counters used by the
    // Firestore-backed rate limiter. Server-only — the Admin SDK bypasses
    // rules so the `rateLimit()` helper can still read/write, but no
    // client (not even super_admin) should touch these docs. Identifiers
    // are hashed before write, so leaking this collection would still
    // not surface raw PII, but locking it down keeps the rules surface
    // minimal and matches the precedent set by notificationDispatchLog.
    match /rateLimitBuckets/{bucketId} {
      allow read, write: if false;
    }

    // ─── Admin Job Runs (T2.2 — observability + run history) ──────────────
    // One doc per job invocation, written/updated exclusively by the
    // admin-jobs service. Denied at the client SDK (deny-all default
    // covers it, but we name it explicitly to defend against a future
    // rules refactor that accidentally reorders the wildcard match).
    // Server-only — Admin SDK reads/writes for the list + detail
    // endpoints. Precedent: checkinLocks, rateLimitBuckets,
    // impersonationCodes, adminJobLocks.
    match /adminJobRuns/{runId} {
      allow read, write: if false;
    }

    // ─── Webhook Events log (T2.1 — payment-provider replay console) ──────
    // Persisted record of every payment-provider webhook we receive.
    // Doc id = `${provider}__${providerTransactionId}__${providerStatus}`
    // so a retry from Wave / Orange Money converges on the same row.
    // Raw body kept for debugging + future signature re-verification;
    // Admin replay re-invokes the handler idempotently from this log.
    // Server-only — no client ever touches it directly. Precedent:
    // rateLimitBuckets, refundLocks, impersonationCodes.
    match /webhookEvents/{eventId} {
      allow read, write: if false;
    }

    // ─── Admin Job Locks (T2.2 — single-flight for the job runner) ─────────
    // One doc per registered jobKey. Written transactionally by the admin-
    // jobs service before a handler starts + deleted in finally. Stale
    // locks (> 5 min) are auto-reclaimable so a crashed handler doesn't
    // wedge the job indefinitely. Server-only — the Admin SDK writes; no
    // client (not even super_admin) reads or mutates directly. Precedent:
    // refundLocks, checkinLocks, rateLimitBuckets.
    match /adminJobLocks/{jobKey} {
      allow read, write: if false;
    }

    // ─── Impersonation Codes (auth-code flow) ──────────────────────────────
    // Short-lived, single-use codes issued by /v1/admin/users/:uid/impersonate
    // and consumed by /v1/impersonation/exchange. Doc id = SHA-256 hex of
    // the raw code (never the raw code itself). Body carries: adminUid,
    // targetUid, targetOrigin, issuedAt, expiresAt, consumedAt, issueIp,
    // issueUa, consumeIp, consumeUa. TTL on `expiresAt` auto-purges expired
    // rows. ALL reads and writes go through the API (Admin SDK bypasses
    // rules). Client-SDK access is denied — leaking this collection would
    // expose timing metadata about admin sessions. Precedent:
    // rateLimitBuckets, notificationDispatchLog.
    match /impersonationCodes/{codeHash} {
      allow read, write: if false;
    }

    // ─── Platform Announcements (Phase D closure + T2.4 read) ────────────
    // Super-admins publish short-lived banners visible across both web
    // apps. Write path is admin-only, goes through the API; client-SDK
    // writes are blocked for audit trail + validation. Reads go through
    // the authenticated `/v1/announcements` API (T2.4), never the
    // client SDK — announcements carry operational context (maintenance
    // notices etc.) that anonymous clients have no business seeing.
    match /announcements/{announcementId} {
      allow read, write: if false;
    }

    // ─── API Keys (T2.3 — organization-scoped bearer credentials) ─────────
    // Doc id = first 10 chars of the plaintext key's entropy-bearing
    // body (hashPrefix). Stored: SHA-256(key) + metadata. Plaintext is
    // NEVER persisted. Server-only at the rules layer — the issuance UI
    // talks exclusively to /v1/organizations/:orgId/api-keys which
    // reads + writes via the Admin SDK. Exposing these docs to the
    // client SDK would leak enough data to correlate a leaked prefix
    // with its org + scopes, lowering the bar for targeted misuse.
    // Precedent: impersonationCodes, webhookEvents, refundLocks.
    match /apiKeys/{apiKeyId} {
      allow read, write: if false;
    }

    // ─── Sprint-3 T4.2 — Firestore read-volume usage tracker ──────────────
    // Server-only: doc ids encode `${orgId}_${day}` and the only
    // writer is the `flushFirestoreUsage` hook (Admin SDK). Operators
    // read aggregates exclusively via the `/v1/admin/usage/firestore`
    // admin endpoint — direct client access would expose cross-org
    // read counts that aren't part of any user-facing surface.
    match /firestoreUsage/{usageDocId} {
      allow read, write: if false;
    }

    // ─── Sprint-4 T3.2 — Scheduled admin operations ───────────────────────
    // Server-only. Operators CRUD via the admin routes; the
    // out-of-process Cloud Functions trigger reads via the Admin
    // SDK. No client SDK path — opening one would leak the
    // `jobInput` contents, which can carry sensitive task params.
    // Deny-all is the same defence-in-depth pattern as `apiKeys`
    // and `webhookEvents`.
    match /scheduledAdminOps/{opId} {
      allow read, write: if false;
    }

    // ─── Sprint C.3 (Sprint-A audit closure) — Server-only collections ────
    // Eight collections that were previously covered only by the
    // top-level deny-all default. Making the deny explicit here keeps
    // operator/audit reviews honest: a future reader doesn't have to
    // infer "no match block = denied". Every entry below is intentional
    // and has its rationale inline.

    // Payouts — money-out ledger. Admin SDK only writes; reads go through
    // the API for org-scoped access + super-admin cross-org views.
    match /payouts/{payoutId} {
      allow read, write: if false;
    }

    // Receipts — invoice trail. Admin SDK writes only; client read goes
    // through the API which handles org-scoping and audit logging.
    match /receipts/{receiptId} {
      allow read, write: if false;
    }

    // Subscriptions — billing state per org. The API is the only writer
    // and reader; clients read derived plan info via the org doc
    // (effectiveLimits / effectiveFeatures) — see ADR-0006.
    match /subscriptions/{subId} {
      allow read, write: if false;
    }

    // Counters — atomic increments only via Firestore transactions on the
    // API server. Direct client access would defeat the transactional
    // invariants (registration counts, badge counts).
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // Refund locks — in-flight refund serialisation locks created and
    // released inside the refund transaction. Lifecycle is short-lived
    // (sub-second). Never seeded, never client-accessed.
    match /refundLocks/{lockId} {
      allow read, write: if false;
    }

    // Payout locks — deterministic idempotency sentinels for payout
    // sweeps (P1-01 / payments audit C2). Doc id is a composite of
    // (orgId, eventId, periodFrom, periodTo); existence proves a
    // payout has already been created for that period. Permanent
    // (one payout per period); deletion only via the super-admin
    // soft-cancel-payout flow. Admin SDK only — never client-accessed.
    match /payoutLocks/{lockId} {
      allow read, write: if false;
    }

    // Feature flags — platform-wide toggles. Read goes through the API
    // (`useFeatureFlag` hook + the future server-side evaluator); writes
    // are super-admin-only via the admin routes. Direct client read
    // would let any caller enumerate the entire flag inventory.
    match /featureFlags/{flagKey} {
      allow read, write: if false;
    }

    // Notification preferences — user-scoped opt-in/opt-out. Owner can
    // read + update their own document; nobody else (incl. organizers)
    // can. The doc id IS the user id, which keeps the rule trivial.
    match /notificationPreferences/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow create: if false; // created server-side on first user signup
      allow delete: if false; // soft-managed via prefs payload
    }

    // Session bookmarks — user's saved sessions. Owner reads + writes
    // their own bookmarks. Other users (and organizers) cannot see who
    // bookmarked what.
    match /sessionBookmarks/{bookmarkId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if false; // bookmarks are create-or-delete only
    }

    // ─── Plan Catalog ──────────────────────────────────────────────────────
    // Superadmin-managed catalog of subscription plans. Any authenticated
    // user can read published (public, non-archived) plans so the billing
    // page works without elevated permissions. Superadmins can read every
    // plan, including archived/private ones.
    // Writes go through the API (admin routes) — client-side mutations are
    // blocked even for superadmins to preserve audit trail and validation.
    match /plans/{planId} {
      allow read: if isAuthenticated()
                  && resource.data.isPublic == true
                  && resource.data.isArchived == false;
      allow read: if isSuperAdmin();

      allow create, update, delete: if false;
    }
  }
}

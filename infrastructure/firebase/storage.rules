rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper Functions ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function hasRole(role) {
      return isAuthenticated() && role in request.auth.token.roles;
    }

    function isOrgMember() {
      return isAuthenticated() && request.auth.token.organizationId != null;
    }

    function belongsToOrg(orgId) {
      return isAuthenticated() && request.auth.token.organizationId == orgId;
    }

    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches('image/(png|jpeg|jpg|gif|webp)');
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    // ─── Deny all by default ───────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ─── Profile Photos ────────────────────────────────────────────────────
    match /users/{userId}/profile/{filename} {
      allow read: if isAuthenticated();
      allow write: if currentUid() == userId && isImage() && maxSize(5);
    }

    // ─── Event Assets ──────────────────────────────────────────────────────
    // Readable by authenticated users only (not public to prevent asset scraping)
    match /events/{eventId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if hasRole('organizer') && isImage() && maxSize(10)
                   && belongsToOrg(
                       firestore.get(/databases/(default)/documents/events/$(eventId)).data.organizationId
                   );
    }

    // ─── Organization Logos ────────────────────────────────────────────────
    // Logos are semi-public (needed for event listings) — require auth
    match /organizations/{orgId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if hasRole('organizer') && isImage() && maxSize(5)
                   && belongsToOrg(orgId);
    }

    // ─── Badges (PDF) — written by Cloud Functions only ───────────────────
    match /badges/{eventId}/{userId}/{filename} {
      allow read: if isAuthenticated()
                  && (currentUid() == userId
                      || hasRole('organizer')
                      || hasRole('super_admin'));
      allow write: if false; // Admin SDK only via Cloud Functions
    }

    // ─── Speaker Assets ─────────────────────────────────────────────────
    // Photos and presentation slides/documents
    match /speakers/{speakerId}/{purpose}/{filename} {
      allow read: if isAuthenticated();
      allow write: if ((currentUid() == speakerId && hasRole('speaker'))
                   || hasRole('organizer'))
                   && (isImage() || isPdf())
                   && maxSize(20); // slides can be larger
    }

    // ─── Sponsor Assets ──────────────────────────────────────────────────
    // Logos, booth banners, marketing materials
    match /sponsors/{sponsorId}/{purpose}/{filename} {
      allow read: if isAuthenticated();
      allow write: if ((currentUid() == sponsorId && hasRole('sponsor'))
                   || hasRole('organizer'))
                   && isImage()
                   && maxSize(10);
    }

    // ─── Feed Media ────────────────────────────────────────────────────────
    match /feed/{postId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && isImage()
                   && maxSize(8);
    }

    // ─── Message Attachments ───────────────────────────────────────────────
    match /messages/{conversationId}/{filename} {
      allow read: if isAuthenticated()
                  && currentUid() in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participantIds;
      allow write: if isAuthenticated()
                   && currentUid() in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participantIds
                   && (isImage() || isPdf())
                   && maxSize(15);
    }

    // ─── Venue Photos ──────────────────────────────────────────────────────
    // Venues are semi-public (used in event listings) — require auth for read
    match /venues/{venueId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if (hasRole('organizer')
                       && belongsToOrg(
                           firestore.get(/databases/(default)/documents/venues/$(venueId)).data.hostOrganizationId
                       )
                   || hasRole('super_admin'))
                   && isImage()
                   && maxSize(10);
    }

    // ─── Badge Template Logos ──────────────────────────────────────────────
    // Needed by any authenticated user to render badges
    match /badge-templates/{templateId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if (hasRole('organizer')
                       && belongsToOrg(
                           firestore.get(/databases/(default)/documents/badgeTemplates/$(templateId)).data.organizationId
                       )
                   || hasRole('super_admin'))
                   && isImage()
                   && maxSize(5);
    }

    // ─── Event Cover Images ────────────────────────────────────────────────
    // Nested path for event cover photos (separate from general event assets)
    match /events/{eventId}/covers/{filename} {
      allow read: if isAuthenticated();
      allow write: if hasRole('organizer') && isImage() && maxSize(10)
                   && belongsToOrg(
                       firestore.get(/databases/(default)/documents/events/$(eventId)).data.organizationId
                   );
    }
  }
}

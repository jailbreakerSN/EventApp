{
  "name": "@teranga/shared-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React UI components for Teranga web apps",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./lib/utils": "./src/lib/utils.ts"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:test": "test-storybook",
    "storybook:test:ci": "concurrently -k -s first -n SB,TEST -c magenta,blue \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --ci --url http://127.0.0.1:6006\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/test-runner": "^0.19.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jest-image-snapshot": "^6.4.0",
    "@types/react": "^19.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.10.3",
    "concurrently": "^9.2.0",
    "http-server": "^14.1.1",
    "jest-image-snapshot": "^6.5.1",
    "playwright": "~1.56.0",
    "postcss": "^8.5.10",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  }
}
